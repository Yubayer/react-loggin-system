/* ------------------------------------------------------------
 * DEMO 1: MIDDLEWARE SETUP
 *
 * Middleware হলো এমন function যে প্রতিটা log entry
 * console এ যাওয়ার সাথে সাথে পায়।
 *
 * Use case:
 *   - Error monitoring (Sentry, Datadog)
 *   - Remote logging (কোনো API তে পাঠানো)
 *   - Analytics event tracking
 *
 * Important: middleware async হতে পারে, কিন্তু
 * logger main thread block করবে না।
 * ------------------------------------------------------------ */
const errorMonitor = async (log) => {
  if (log.level === 'error') {
    // real app এ: await Sentry.captureMessage(log.message, log.data)
    console.log('📤 Error monitor received:', log);
  }
};

logger.use(errorMonitor);

/* middleware remove করার example:
   logger.remove(errorMonitor);
*/


/* ------------------------------------------------------------
 * DEMO 2: ROUTER TRACKING — React Router v7
 *
 * React Router v7 এ router object এ subscribe() আছে।
 * সেটা trackRoutes() এ দিলে route change
 * automatically log হয়।
 *
 * React component এ কীভাবে করবে:
 *
 *   import { createBrowserRouter } from 'react-router';
 *
 *   const router = createBrowserRouter([...]);
 *   logger.trackRoutes(router);
 *
 *   // Component unmount এ:
 *   useEffect(() => {
 *     logger.trackRoutes(router);
 *     return () => logger.untrackRoutes();
 *   }, []);
 *
 * নিচে mock দিয়ে simulate করা হয়েছে:
 * ------------------------------------------------------------ */
const mockRouter = {
  _listeners : [],

  subscribe(fn) {
    this._listeners.push(fn);
    // React Router v7 unsubscribe pattern return করে
    return () => {
      this._listeners = this._listeners.filter(l => l !== fn);
    };
  },

  navigate(path) {
    this._listeners.forEach(fn =>
      fn({ location: { pathname: path, search: '' } })
    );
  },
};

logger.trackRoutes(mockRouter);

mockRouter.navigate('/shop');
mockRouter.navigate('/product/101');
mockRouter.navigate('/checkout');

/* এখন untrack করা যাবে যেকোনো সময়:
   logger.untrackRoutes();
*/


