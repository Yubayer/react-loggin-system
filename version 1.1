/* ------------------------------------------------------------
 * DEMO 11: MIDDLEWARE REMOVAL
 *
 * Conditional middleware — শুধু authenticated user এর
 * জন্য remote logging চালু করার example।
 * ------------------------------------------------------------ */
const remoteLogger = async (log) => {
  // real app এ:
  // await fetch('/api/logs', { method: 'POST', body: JSON.stringify(log) });
