/**
 * ============================================================
 *  JHLogger — Production-Grade Logger
 *  Framework : React Router v7 / SPA / Node-safe
 *  Author    : Jobayer Hossain
 * ============================================================
 */

class JHLogger {

  /* ----------------------------------------------------------
   * STATIC LEVEL MAP
   * প্রতিটা level এর numeric priority।
   * static রাখার কারণ: প্রতি instance এ নতুন object
   * তৈরি হওয়া wasteful — এটা সবার জন্য একই।
   * ---------------------------------------------------------- */
  static _LEVELS = {
    debug : 0,
    info  : 1,
    warn  : 2,
    error : 3,
  };

  /* ----------------------------------------------------------
   * PRIVATE FIELDS  (#)
   * JavaScript private class fields — বাইরে থেকে
   * সরাসরি access বা overwrite করা যাবে না।
   * শুধু getter/setter দিয়ে controlled access।
   * ---------------------------------------------------------- */
  #verbose      = false;
  #level        = 'info';
  #middlewares  = [];
  #routerUnsub  = null;
  #store        = [];

  /* ----------------------------------------------------------
   * CONSTANTS
   * ---------------------------------------------------------- */
  static #MAX_MIDDLEWARES = 20;
  static #MAX_STORE       = 200;

  /* ----------------------------------------------------------
   * CONSTRUCTOR
   * ---------------------------------------------------------- */
  constructor(options = {}) {
    this.enabled  = options.enabled  ?? true;
    this.#verbose = options.verbose  ?? false;
    this.#level   = options.level    ?? 'info';
  }

  /* ----------------------------------------------------------
   * GETTERS / SETTERS
   *
   * verbose setter — falsy/truthy যা-ই আসুক, Boolean এ
   * convert করে safe রাখে।
   *
   * level setter — invalid value দিলে warn করে এবং
   * পুরনো value ধরে রাখে, crash করে না।
   * ---------------------------------------------------------- */
  get verbose()    { return this.#verbose; }
  set verbose(val) { this.#verbose = Boolean(val); }

  get level()    { return this.#level; }
  set level(val) {
    if (!(val in JHLogger._LEVELS)) {
      console.warn(`[JHLogger] Invalid level: "${val}". Keeping "${this.#level}"`);
      return;
    }
    this.#level = val;
  }

  /* ----------------------------------------------------------
   * fromEnv()  —  STATIC FACTORY
   *
   * Environment দেখে নিজে নিজে config করে instance দেয়।
   * Vite / Cloudflare Pages এ import.meta.env.DEV আছে।
   * Node.js এ process.env.NODE_ENV আছে।
   * দুটোই check করে যেটা পাওয়া যায় সেটা ব্যবহার করে।
   * ---------------------------------------------------------- */
  static fromEnv() {
    const isDev =
      (typeof import.meta !== 'undefined' && import.meta.env?.DEV === true) ||
      (typeof process     !== 'undefined' && process.env?.NODE_ENV === 'development');

    return new JHLogger({
      enabled : true,
      verbose : isDev,
      level   : isDev ? 'debug' : 'error',
    });
  }

  /* ----------------------------------------------------------
   * _canLog()  —  LEVEL GATE
   *
   * বর্তমান minimum level এর চেয়ে ছোট level এর
   * messages skip করে।
   * e.g. level='warn' হলে debug/info print হবে না।
   * ---------------------------------------------------------- */
  _canLog(level) {
    return JHLogger._LEVELS[level] >= JHLogger._LEVELS[this.#level];
  }

  /* ----------------------------------------------------------
   * use()  —  MIDDLEWARE REGISTER
   *
   * প্রতিটা log entry middleware pipeline দিয়ে যায়।
   * Use case: analytics, error monitoring (Sentry), remote logging।
   *
   * Cap: 20 — accidental double-registration ধরার জন্য।
   * Chainable: logger.use(fn1).use(fn2) কাজ করে।
   * ---------------------------------------------------------- */
  use(fn) {
    if (typeof fn !== 'function') {
      throw new TypeError('[JHLogger] use() এ function দিতে হবে');
    }
    if (this.#middlewares.length >= JHLogger.#MAX_MIDDLEWARES) {
      console.warn(`[JHLogger] Middleware cap (${JHLogger.#MAX_MIDDLEWARES}) reached. "${fn.name || 'anonymous'}" যোগ হয়নি।`);
      return this;
    }
    this.#middlewares.push(fn);
    return this;
  }

  /* ----------------------------------------------------------
   * remove()  —  MIDDLEWARE UNREGISTER
   *
   * use() এর বিপরীত।
   * Same function reference দিয়ে তুলে নেওয়া যায়।
   *
   * e.g.
   *   const myMw = (log) => { ... };
   *   logger.use(myMw);
   *   logger.remove(myMw);
   * ---------------------------------------------------------- */
  remove(fn) {
    this.#middlewares = this.#middlewares.filter(mw => mw !== fn);
    return this;
  }

  /* ----------------------------------------------------------
   * _log()  —  CORE ENGINE  (synchronous)
   *
   * কেন synchronous?
   *   Console I/O নিজেই synchronous। async _log থাকলে
   *   caller কে await করতে হয়, না করলে Promise silently
   *   swallow হয়ে যায় — bug ধরা কঠিন হয়।
   *
   * Middleware কীভাবে চলে?
   *   Promise.allSettled() দিয়ে fire-and-forget।
   *   একটা middleware fail করলে বাকিগুলো থামে না।
   *   সব failure console এ দেখা যায়।
   *
   * Store:
   *   শেষ MAX_STORE টি entry memory তে রাখে।
   *   getLogs() দিয়ে query করা যায়।
   * ---------------------------------------------------------- */
  _log(level, message, data) {
    if (!this.enabled || !this._canLog(level)) return;

    const entry = {
      level,
      message,
      data : data ?? null,
      time : new Date().toISOString(),
    };

    // ── Store ──────────────────────────────────────────────
    this.#store.push(entry);
    if (this.#store.length > JHLogger.#MAX_STORE) {
      this.#store.shift();
    }

    // ── Middleware (async, fire-and-forget) ────────────────
    if (this.#middlewares.length > 0) {
      Promise.allSettled(
        this.#middlewares.map(mw => Promise.resolve().then(() => mw(entry)))
      ).then(results => {
        results.forEach((r, i) => {
          if (r.status === 'rejected') {
            console.error(`[JHLogger] Middleware[${i}] error:`, r.reason);
          }
        });
      });
    }

    // ── Console Output ─────────────────────────────────────
    const prefix = `[JH:${level.toUpperCase()}]`;

    if      (level === 'error') console.error(prefix, message, data ?? '');
    else if (level === 'warn')  console.warn (prefix, message, data ?? '');
    else                        console.log  (prefix, message, data ?? '');

    // ── Verbose Dump ───────────────────────────────────────
    if (this.#verbose) {
      console.log('🔎 VERBOSE:', entry);
    }
  }

  /* ----------------------------------------------------------
   * PUBLIC LOG METHODS
   *
   * void return — কেউ await করলেও কিছু হবে না,
   * undefined পাবে, confusion নেই।
   * ---------------------------------------------------------- */
  debug(message, data) { this._log('debug', message, data); }
  info (message, data) { this._log('info',  message, data); }
  warn (message, data) { this._log('warn',  message, data); }
  error(message, data) { this._log('error', message, data); }

  /* ----------------------------------------------------------
   * trackRoutes()  —  REACT ROUTER v7 INTEGRATION
   *
   * router.subscribe() এ listener attach করে।
   * React Router v7 এ subscribe() একটা unsubscribe
   * function return করে — সেটা save করে রাখি।
   *
   * দ্বিতীয়বার trackRoutes() call করলে আগেরটা আগে
   * unsub করে নেয় — duplicate listener এড়ানোর জন্য।
   * ---------------------------------------------------------- */
  trackRoutes(router) {
    if (!router?.subscribe) {
      this.warn('trackRoutes()', 'router.subscribe নেই — tracking বন্ধ');
      return;
    }

    this.untrackRoutes();

    const handler = (state) => {
      this.info('Route Changed', {
        path   : state.location.pathname,
        search : state.location.search,
      });
    };

    const unsub = router.subscribe(handler);
    this.#routerUnsub = typeof unsub === 'function' ? unsub : () => {};
  }

  /* ----------------------------------------------------------
   * untrackRoutes()
   *
   * React Router listener সরিয়ে দেয়।
   * Component unmount বা router destroy হলে call করো।
   * ---------------------------------------------------------- */
  untrackRoutes() {
    this.#routerUnsub?.();
    this.#routerUnsub = null;
  }

  /* ----------------------------------------------------------
   * getLogs()  —  LOG STORE QUERY
   *
   * Memory তে রাখা logs filter করে দেয়।
   * level দিলে শুধু সেই level বা তার উপরেরগুলো আসবে।
   *
   * e.g.
   *   logger.getLogs()           → সব logs
   *   logger.getLogs('warn')     → warn + error
   *   logger.getLogs('error')    → শুধু error
   * ---------------------------------------------------------- */
  getLogs(level) {
    if (!level) return [...this.#store];
    const min = JHLogger._LEVELS[level] ?? 0;
    return this.#store.filter(e => JHLogger._LEVELS[e.level] >= min);
  }

  /* ----------------------------------------------------------
   * clearLogs()
   * ---------------------------------------------------------- */
  clearLogs() {
    this.#store.length = 0;
  }

  /* ----------------------------------------------------------
   * CONSOLE UTILITIES
   *
   * group/time এগুলো logger এর সাথে রাখার কারণ:
   * একই import থেকে সব পাওয়া যায়,
   * আলাদা console.group() মনে রাখতে হয় না।
   * ---------------------------------------------------------- */
  group   (label) { console.group   (`📦 ${label}`); }
  groupEnd()      { console.groupEnd(); }
  time    (label) { console.time    (`⏱ ${label}`); }
  timeEnd (label) { console.timeEnd (`⏱ ${label}`); }
}

/* ============================================================
 * SINGLETON EXPORT
 *
 * সারা app এ একটাই instance — সব জায়গায় same config,
 * same store, same middlewares।
 * আলাদা instance দরকার হলে: new JHLogger({ ... })
 * ============================================================ */
export const logger = JHLogger.fromEnv();
export default JHLogger;


