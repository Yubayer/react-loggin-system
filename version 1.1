/* ============================================================
 *
 *  ┌─────────────────────────────────────────────────────┐
 *  │                  QUICK REFERENCE                    │
 *  ├─────────────────────────────────────────────────────┤
 *  │  logger.debug(msg, data?)   low-level trace         │
 *  │  logger.info(msg, data?)    normal events           │
 *  │  logger.warn(msg, data?)    unexpected but ok       │
 *  │  logger.error(msg, data?)   needs attention         │
 *  ├─────────────────────────────────────────────────────┤
 *  │  logger.use(fn)             middleware add          │
 *  │  logger.remove(fn)          middleware remove       │
 *  ├─────────────────────────────────────────────────────┤
 *  │  logger.trackRoutes(router) route change logging    │
 *  │  logger.untrackRoutes()     cleanup                 │
 *  ├─────────────────────────────────────────────────────┤
 *  │  logger.getLogs(level?)     query store             │
 *  │  logger.clearLogs()         clear store             │
 *  ├─────────────────────────────────────────────────────┤
 *  │  logger.verbose = true/false  toggle dump mode      │
 *  │  logger.level   = 'debug' | 'info' | 'warn' |      │
 *  │                   'error'                           │
 *  ├─────────────────────────────────────────────────────┤
 *  │  logger.group(label)        console group open      │
 *  │  logger.groupEnd()          console group close     │
 *  │  logger.time(label)         start timer             │
 *  │  logger.timeEnd(label)      stop + print timer      │
 *  └─────────────────────────────────────────────────────┘
 *
 *  ENV AUTO-CONFIG (JHLogger.fromEnv()):
 *   development  →  level: debug,  verbose: true
 *   production   →  level: error,  verbose: false
 *
 *  Enable verbose at runtime (browser console):
 *    window.__logger = logger   ← main.js এ set করো
 *    __logger.verbose = true
 *    __logger.level = 'debug'
 *
 * ============================================================ */
