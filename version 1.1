});


/* ------------------------------------------------------------
 * DEMO 4: CART FLOW — group + time
 *
 * group() দিয়ে related logs একসাথে collapse করা যায়।
 * DevTools এ পড়তে অনেক সহজ হয়।
 *
 * time() / timeEnd() দিয়ে কোনো operation কত সময়
 * নিলো measure করা যায়।
 * ------------------------------------------------------------ */
function addToCart(product) {
  logger.group('Cart Flow');

  logger.info('Product added', { id: product.id, name: product.name });
  logger.debug('Cart state updating...');
  logger.time('cart-save');

  // async operation simulate
  setTimeout(() => {
    logger.info('Cart saved to server');
    logger.timeEnd('cart-save');
    logger.groupEnd();
  }, 500);
}

addToCart({ id: 101, name: 'Premium T-Shirt', price: 899 });


/* ------------------------------------------------------------
 * DEMO 5: CHECKOUT FLOW — error handling
 *
 * try/catch এর ভেতরে error লগ করার সঠিক উপায়।
 * error() তে error object টাও data হিসেবে পাঠাও —
 * stack trace পরে debugging এ কাজে লাগে।
 * ------------------------------------------------------------ */
function processCheckout(cartId) {
  logger.group('Checkout Flow');
  logger.info('Checkout initiated', { cartId });

  try {
    // simulate payment failure
    throw new Error('Payment gateway timeout');
  } catch (err) {
    logger.error('Checkout failed', {
      message : err.message,
      stack   : err.stack,
      cartId,
    });
  } finally {
    logger.groupEnd();
  }
}

processCheckout('cart_abc123');


/* ------------------------------------------------------------
 * DEMO 6: ANALYTICS EVENT TRACKING
 *
 * User action এর জন্য structured event log।
 * Middleware এ এই info events ধরে analytics
 * platform এ পাঠানো যায় (Mixpanel, Amplitude)।
 * ------------------------------------------------------------ */
function trackEvent(name, properties = {}) {
  logger.info('Analytics Event', {
    event      : name,
    properties,
    timestamp  : Date.now(),
  });
}

trackEvent('product_viewed',  { productId: 101, source: 'search' });
trackEvent('add_to_cart',     { productId: 101, quantity: 1 });
trackEvent('checkout_started',{ cartValue: 899, currency: 'BDT' });


